      <command>#!/usr/bin/env bash
set -e
source /etc/profile.d/maven.sh
rm -rf target/
COMMIT_SHA1=`echo $GIT_COMMIT | cut -c-7`
echo &quot;build.number=${BUILD_NUMBER}-${COMMIT_SHA1}&quot; &gt; $WORKSPACE/src/main/java/BuildNumber.properties
mvn clean -DcompilerArgument=-Xlint:unchecked test -P all-unit-tests package
echo &quot;generate HTML SureFire output&quot;
mvn surefire-report:report
</command>
      <configuredLocalRules/>
    </hudson.tasks.Shell>
    <hudson.tasks.Shell>
      <command>#!/usr/bin/env bash
set -euo pipefail

echo &quot;=== Build &amp; unit tests (Surefire) ===&quot;
# Earliest form you used:
mvn -B clean verify -DskipITs

echo &quot;=== Generate HTML SureFire output ===&quot;
# This produces target/site/surefire-report.html
mvn -B surefire-report:report

echo &quot;=== Summarize Surefire results (txt/xml) ===&quot;
if ls target/surefire-reports/*.txt &gt;/dev/null 2&gt;&amp;1; then
  for f in target/surefire-reports/*.txt; do
    echo &quot;--- $f ---&quot;
    tail -n 200 &quot;$f&quot; || true
  done
fi
ls -lah target/surefire-reports/*.xml || true

echo &quot;=== List HTML report location ===&quot;
ls -lah target/site || true
[ -f target/site/surefire-report.html ] &amp;&amp; echo &quot;HTML: target/site/surefire-report.html&quot;

echo &quot;=== Collect artifacts for archiving ===&quot;
ARTDIR=&quot;$WORKSPACE/artifacts&quot;
mkdir -p &quot;$ARTDIR&quot;
cp -R target/surefire-reports &quot;$ARTDIR/&quot; || true
[ -d target/site ] &amp;&amp; cp -R target/site &quot;$ARTDIR/&quot; || true
[ -f target/dataverse-5.13.war ] &amp;&amp; cp target/dataverse-5.13.war &quot;$ARTDIR/&quot; || true

echo &quot;=== Target dir sanity ===&quot;
ls -lah target || true
</command>
      <configuredLocalRules/>
    </hudson.tasks.Shell>
